{
  "name": "memberwiki",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "bun run tools/setup.ts",
    "dev": "concurrently -n fe,be -c cyan,green \"bun --cwd frontend dev\" \"bun --cwd backend dev\"",
    "test": "bun run tools/test.ts test",
    "lint": "bun --cwd frontend lint; bun run tools/lint.ts",
    "typecheck": "bun --cwd frontend typecheck; bun run tools/typecheck.ts",
    "clean": "bun run tools/clean.ts all",
    "clean:db": "bun run tools/db.ts reset",
    "clean:logs": "bun run tools/logs.ts --clean",
    "clean:cache": "bun run tools/clean.ts cache",
    "logs": "bun run tools/logs.ts",
    "update": "bun run tools/update.ts",
    "help": "bun run tools/help.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "concurrently": "^9.1.2"
  }
}
